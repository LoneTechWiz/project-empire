# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Then source it before running the backend:
#   source .env

export DB_URL=jdbc:postgresql://localhost:5432/empire
export DB_USER=your_db_user
export DB_PASSWORD=your_db_password
export JWT_SECRET=replace-with-a-long-random-secret-at-least-256-bits
export TICK_MS=600000
export CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3001
