<%- include('../partials/header', { title: alliance.name }) %>

<div class="alliance-header" style="border-left: 6px solid <%= alliance.color %>;">
  <img src="<%= alliance.flag_url %>" class="alliance-header-flag" onerror="this.src='/img/default_alliance_flag.png'">
  <div>
    <h1>[<%= alliance.acronym %>] <%= alliance.name %></h1>
    <p><%= alliance.description || 'No description.' %></p>
    <p>
      <% if (alliance.forum_link) { %><a href="<%= alliance.forum_link %>" target="_blank">Forum</a> &bull; <% } %>
      <% if (alliance.discord_link) { %><a href="<%= alliance.discord_link %>" target="_blank">Discord</a><% } %>
    </p>
  </div>
  <div class="alliance-header-actions">
    <% if (isMember) { %>
      <% if (isLeader) { %><a href="/alliances/<%= alliance.id %>/edit" class="btn btn-secondary">Edit Alliance</a><% } %>
      <form method="POST" action="/alliances/<%= alliance.id %>/leave">
        <button class="btn btn-danger">Leave Alliance</button>
      </form>
    <% } else if (nation && !nation.alliance_id) { %>
      <form method="POST" action="/alliances/<%= alliance.id %>/apply">
        <button class="btn btn-primary">Apply to Join</button>
      </form>
    <% } %>
  </div>
</div>

<% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
<% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

<div class="content-grid">
  <div class="content-main">
    <!-- Members -->
    <div class="panel">
      <h2>Members (<%= members.length %>)</h2>
      <table class="data-table">
        <thead><tr><th>Rank</th><th>Nation</th><th>Position</th><th>Score</th><th>Cities</th><% if (isLeader) { %><th>Actions</th><% } %></tr></thead>
        <tbody>
          <% members.forEach((m, i) => { %>
          <tr>
            <td>#<%= i+1 %></td>
            <td><a href="/nation/<%= m.id %>"><%= m.name %></a><br><small><%= m.leader_name %></small></td>
            <td><span class="position-badge position-<%= m.alliance_position.toLowerCase() %>"><%= m.alliance_position %></span></td>
            <td><%= formatDecimal(m.score, 2) %></td>
            <td><%= m.city_count || 0 %></td>
            <% if (isLeader && m.id !== nation.id) { %>
            <td>
              <form method="POST" action="/alliances/<%= alliance.id %>/promote/<%= m.id %>" style="display:inline">
                <button class="btn btn-sm btn-secondary">Promote</button>
              </form>
            </td>
            <% } %>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- Applicants -->
    <% if (isLeader && applicants.length > 0) { %>
    <div class="panel">
      <h2>Applications (<%= applicants.length %>)</h2>
      <% applicants.forEach(a => { %>
        <div class="applicant-row">
          <a href="/nation/<%= a.id %>"><%= a.name %></a> (<%= a.leader_name %>)
          Score: <%= formatDecimal(a.score, 2) %>
          <form method="POST" action="/alliances/<%= alliance.id %>/accept/<%= a.id %>" style="display:inline">
            <button class="btn btn-sm btn-primary">Accept</button>
          </form>
          <form method="POST" action="/alliances/<%= alliance.id %>/reject/<%= a.id %>" style="display:inline">
            <button class="btn btn-sm btn-danger">Reject</button>
          </form>
        </div>
      <% }) %>
    </div>
    <% } %>
  </div>

  <div class="content-sidebar">
    <!-- Alliance Bank -->
    <div class="panel">
      <h3>🏦 Alliance Bank</h3>
      <div class="bank-resources">
        <div>💰 <%= formatMoney(alliance.bank_money) %></div>
        <div>🌾 <%= formatNumber(alliance.bank_food) %> food</div>
        <div>⚫ <%= formatNumber(alliance.bank_coal) %> coal</div>
        <div>🛢️ <%= formatNumber(alliance.bank_oil) %> oil</div>
        <div>🔩 <%= formatNumber(alliance.bank_iron) %> iron</div>
        <div>🪨 <%= formatNumber(alliance.bank_bauxite) %> bauxite</div>
        <div>🔘 <%= formatNumber(alliance.bank_lead) %> lead</div>
        <div>☢️ <%= formatNumber(alliance.bank_uranium) %> uranium</div>
        <div>⛽ <%= formatNumber(alliance.bank_gasoline) %> gas</div>
        <div>💣 <%= formatNumber(alliance.bank_munitions) %> mun</div>
        <div>🔧 <%= formatNumber(alliance.bank_steel) %> steel</div>
        <div>⬜ <%= formatNumber(alliance.bank_aluminum) %> alum</div>
      </div>

      <% if (isMember && nation.alliance_position !== 'Applicant') { %>
      <details>
        <summary>Deposit Resources</summary>
        <form method="POST" action="/alliances/<%= alliance.id %>/bank/deposit" class="bank-form">
          <input type="number" name="money" placeholder="Money" min="0" step="1000">
          <input type="number" name="food" placeholder="Food" min="0">
          <input type="number" name="coal" placeholder="Coal" min="0">
          <input type="number" name="oil" placeholder="Oil" min="0">
          <input type="number" name="steel" placeholder="Steel" min="0">
          <button class="btn btn-sm btn-primary">Deposit</button>
        </form>
      </details>

      <% if (isLeader) { %>
      <details>
        <summary>Withdraw Resources</summary>
        <form method="POST" action="/alliances/<%= alliance.id %>/bank/withdraw" class="bank-form">
          <select name="target_nation">
            <% members.forEach(m => { %>
              <option value="<%= m.id %>"><%= m.name %></option>
            <% }) %>
          </select>
          <input type="number" name="money" placeholder="Money" min="0">
          <input type="number" name="food" placeholder="Food" min="0">
          <input type="number" name="coal" placeholder="Coal" min="0">
          <input type="number" name="steel" placeholder="Steel" min="0">
          <button class="btn btn-sm btn-primary">Withdraw</button>
        </form>
      </details>
      <% } %>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
