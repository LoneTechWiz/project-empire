<%- include('../partials/header', { title: 'Alliances' }) %>

<div class="page-header">
  <h1>🤝 Alliances</h1>
  <% if (nation && !nation.alliance_id) { %>
    <a href="/alliances/create" class="btn btn-primary">Create Alliance</a>
  <% } %>
</div>

<div class="alliance-list">
  <% if (alliances.length === 0) { %>
    <div class="panel"><p class="text-muted">No alliances yet.</p></div>
  <% } %>
  <% alliances.forEach((a, i) => { %>
  <div class="alliance-row" style="border-left: 4px solid <%= a.color %>;">
    <div class="alliance-rank">#<%= i + 1 %></div>
    <div class="alliance-flag">
      <img src="<%= a.flag_url %>" onerror="this.src='/img/default_alliance_flag.png'" style="width:50px;height:35px;object-fit:cover;">
    </div>
    <div class="alliance-info">
      <h3><a href="/alliances/<%= a.id %>">[<%= a.acronym %>] <%= a.name %></a></h3>
      <span class="tag" style="background:<%= a.color %>"><%= a.color %></span>
    </div>
    <div class="alliance-stats">
      <div><strong><%= a.member_count %></strong> Members</div>
    </div>
    <div class="alliance-actions">
      <a href="/alliances/<%= a.id %>" class="btn btn-secondary btn-sm">View</a>
      <% if (nation && !nation.alliance_id) { %>
        <form method="POST" action="/alliances/<%= a.id %>/apply" style="display:inline">
          <button class="btn btn-primary btn-sm">Apply</button>
        </form>
      <% } %>
    </div>
  </div>
  <% }) %>
</div>

<%- include('../partials/footer') %>
