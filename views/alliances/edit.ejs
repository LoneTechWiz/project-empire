<%- include('../partials/header', { title: 'Edit Alliance' }) %>
<div class="page-header"><h1>Edit Alliance: <%= alliance.name %></h1></div>
<% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
<form method="POST" action="/alliances/<%= alliance.id %>/edit" class="form-card">
  <div class="form-group">
    <label>Description</label>
    <textarea name="description" rows="4"><%= alliance.description %></textarea>
  </div>
  <div class="form-row">
    <div class="form-group">
      <label>Forum Link</label>
      <input type="url" name="forum_link" value="<%= alliance.forum_link %>">
    </div>
    <div class="form-group">
      <label>Discord Link</label>
      <input type="url" name="discord_link" value="<%= alliance.discord_link %>">
    </div>
  </div>
  <div class="form-group">
    <label>Color</label>
    <div class="color-picker">
      <% COLORS.forEach(c => { %>
        <label class="color-option">
          <input type="radio" name="color" value="<%= c %>" <%= alliance.color === c ? 'checked' : '' %>>
          <span class="color-swatch" style="background-color: <%= c %>;"></span>
        </label>
      <% }) %>
    </div>
  </div>
  <button type="submit" class="btn btn-primary">Save Changes</button>
  <a href="/alliances/<%= alliance.id %>" class="btn btn-secondary">Cancel</a>
</form>
<%- include('../partials/footer') %>
