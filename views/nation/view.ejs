<%- include('../partials/header', { title: nation.name }) %>

<div class="nation-header" style="border-left: 6px solid <%= nation.color %>;">
  <div class="nation-flag">
    <img src="<%= nation.flag_url %>" alt="<%= nation.name %> flag" onerror="this.src='/img/default_flag.png'">
  </div>
  <div class="nation-info">
    <h1><%= nation.name %></h1>
    <p class="nation-leader">Led by <strong><%= nation.leader_name %></strong> &bull; <%= nation.government_type %> &bull; <%= nation.continent %></p>
    <p class="nation-meta">
      <span class="tag"><%= nation.color %></span>
      <span class="tag"><%= nation.religion %></span>
      <% if (alliance) { %>
        <a href="/alliances/<%= alliance.id %>" class="tag tag-alliance">[<%= alliance.acronym %>] <%= alliance.name %> &bull; <%= nation.alliance_position %></a>
      <% } else { %>
        <span class="tag tag-none">No Alliance</span>
      <% } %>
      <% if (nation.beige_turns > 0) { %>
        <span class="tag tag-beige">🛡️ Beige (<%= nation.beige_turns %> turns)</span>
      <% } %>
    </p>
    <p class="nation-score">Score: <strong><%= formatDecimal(nation.score, 2) %></strong> &bull; Founded: <%= new Date(nation.founded_date).toLocaleDateString() %></p>
  </div>
  <% if (isOwn) { %>
  <div class="nation-actions">
    <a href="/nation/<%= nation.id %>/edit" class="btn btn-secondary">Edit Nation</a>
    <a href="/wars/declare/<%= nation.id %>" style="display:none">Declare War</a>
  </div>
  <% } else if (locals.nation) { %>
  <div class="nation-actions">
    <a href="/wars/declare/<%= nation.id %>" class="btn btn-danger">⚔️ Declare War</a>
    <a href="/messages/compose?to=<%= nation.id %>" class="btn btn-secondary">✉️ Message</a>
  </div>
  <% } %>
</div>

<div class="content-grid">
  <div class="content-main">
    <!-- Resources -->
    <div class="panel">
      <h2>Resources</h2>
      <div class="resource-grid">
        <div class="resource-item"><span class="res-icon">💰</span><span class="res-label">Money</span><span class="res-value"><%= formatMoney(nation.money) %></span></div>
        <div class="resource-item"><span class="res-icon">🌾</span><span class="res-label">Food</span><span class="res-value"><%= formatNumber(nation.food) %></span></div>
        <div class="resource-item"><span class="res-icon">⚫</span><span class="res-label">Coal</span><span class="res-value"><%= formatNumber(nation.coal) %></span></div>
        <div class="resource-item"><span class="res-icon">🛢️</span><span class="res-label">Oil</span><span class="res-value"><%= formatNumber(nation.oil) %></span></div>
        <div class="resource-item"><span class="res-icon">☢️</span><span class="res-label">Uranium</span><span class="res-value"><%= formatNumber(nation.uranium) %></span></div>
        <div class="resource-item"><span class="res-icon">🔩</span><span class="res-label">Iron</span><span class="res-value"><%= formatNumber(nation.iron) %></span></div>
        <div class="resource-item"><span class="res-icon">🪨</span><span class="res-label">Bauxite</span><span class="res-value"><%= formatNumber(nation.bauxite) %></span></div>
        <div class="resource-item"><span class="res-icon">🔘</span><span class="res-label">Lead</span><span class="res-value"><%= formatNumber(nation.lead) %></span></div>
        <div class="resource-item"><span class="res-icon">⛽</span><span class="res-label">Gasoline</span><span class="res-value"><%= formatNumber(nation.gasoline) %></span></div>
        <div class="resource-item"><span class="res-icon">💣</span><span class="res-label">Munitions</span><span class="res-value"><%= formatNumber(nation.munitions) %></span></div>
        <div class="resource-item"><span class="res-icon">🔧</span><span class="res-label">Steel</span><span class="res-value"><%= formatNumber(nation.steel) %></span></div>
        <div class="resource-item"><span class="res-icon">⬜</span><span class="res-label">Aluminum</span><span class="res-value"><%= formatNumber(nation.aluminum) %></span></div>
      </div>
    </div>

    <!-- Military -->
    <div class="panel">
      <h2>Military</h2>
      <div class="military-grid">
        <div class="mil-item"><span class="mil-icon">👥</span><span class="mil-label">Soldiers</span><span class="mil-value"><%= formatNumber(nation.soldiers) %></span></div>
        <div class="mil-item"><span class="mil-icon">🚗</span><span class="mil-label">Tanks</span><span class="mil-value"><%= formatNumber(nation.tanks) %></span></div>
        <div class="mil-item"><span class="mil-icon">✈️</span><span class="mil-label">Aircraft</span><span class="mil-value"><%= formatNumber(nation.aircraft) %></span></div>
        <div class="mil-item"><span class="mil-icon">🚢</span><span class="mil-label">Ships</span><span class="mil-value"><%= formatNumber(nation.ships) %></span></div>
        <div class="mil-item"><span class="mil-icon">🕵️</span><span class="mil-label">Spies</span><span class="mil-value"><%= formatNumber(nation.spies) %></span></div>
        <div class="mil-item"><span class="mil-icon">🚀</span><span class="mil-label">Missiles</span><span class="mil-value"><%= formatNumber(nation.missiles) %></span></div>
        <div class="mil-item"><span class="mil-icon">☢️</span><span class="mil-label">Nukes</span><span class="mil-value"><%= formatNumber(nation.nukes) %></span></div>
      </div>
      <div class="war-record">
        Wars: <strong class="win"><%= nation.offensive_wars_won + nation.defensive_wars_won %> W</strong> /
        <strong class="loss"><%= nation.offensive_wars_lost + nation.defensive_wars_lost %> L</strong>
      </div>
    </div>

    <!-- Cities -->
    <div class="panel">
      <h2>Cities (<%= cities.length %>)</h2>
      <div class="city-list">
        <% cities.forEach(city => { %>
        <div class="city-item">
          <span class="city-name"><%= city.name %></span>
          <span class="city-infra">Infra: <%= formatDecimal(city.infrastructure, 0) %></span>
          <span class="city-land">Land: <%= formatDecimal(city.land, 0) %></span>
          <span class="city-power <%= city.power.powered ? 'powered' : 'unpowered' %>">
            <%= city.power.powered ? '⚡ Powered' : '🔴 No Power' %>
          </span>
        </div>
        <% }) %>
      </div>
    </div>
  </div>

  <div class="content-sidebar">
    <!-- Active Wars -->
    <% if (activeWars.length > 0) { %>
    <div class="panel panel-danger">
      <h3>⚔️ Active Wars (<%= activeWars.length %>)</h3>
      <% activeWars.forEach(w => { %>
        <div class="war-item">
          <a href="/wars/<%= w.id %>"><%= w.attacker_name %> vs <%= w.defender_name %></a>
        </div>
      <% }) %>
    </div>
    <% } %>

    <!-- Projects -->
    <% if (projects.length > 0) { %>
    <div class="panel">
      <h3>🏗️ National Projects</h3>
      <% projects.forEach(p => { %>
        <div class="project-item"><span class="project-icon">✅</span><%= p %></div>
      <% }) %>
    </div>
    <% } %>

    <!-- Activity Log -->
    <div class="panel">
      <h3>📜 Recent Activity</h3>
      <% if (recentActivity.length === 0) { %>
        <p class="text-muted">No recent activity.</p>
      <% } else { %>
        <% recentActivity.forEach(a => { %>
          <div class="activity-item">
            <span class="activity-msg"><%= a.message %></span>
            <span class="activity-time"><%= timeAgo(a.created_at) %></span>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
