<%- include('../partials/header', { title: 'Edit Nation' }) %>
<div class="page-header">
  <h1>Edit Nation Settings</h1>
</div>
<% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
<form method="POST" action="/nation/<%= nation.id %>/edit" class="form-card">
  <div class="form-row">
    <div class="form-group">
      <label>Leader Name</label>
      <input type="text" name="leader_name" value="<%= nation.leader_name %>" required>
    </div>
    <div class="form-group">
      <label>Capital</label>
      <input type="text" name="capital" value="<%= nation.capital %>">
    </div>
  </div>
  <div class="form-row">
    <div class="form-group">
      <label>Government Type</label>
      <select name="government_type">
        <% GOVERNMENTS.forEach(g => { %>
          <option value="<%= g %>" <%= nation.government_type === g ? 'selected' : '' %>><%= g %></option>
        <% }) %>
      </select>
    </div>
    <div class="form-group">
      <label>Religion</label>
      <select name="religion">
        <% RELIGIONS.forEach(r => { %>
          <option value="<%= r %>" <%= nation.religion === r ? 'selected' : '' %>><%= r %></option>
        <% }) %>
      </select>
    </div>
  </div>
  <div class="form-row">
    <div class="form-group">
      <label>War Policy</label>
      <select name="war_policy">
        <% WAR_POLICIES.forEach(p => { %>
          <option value="<%= p %>" <%= nation.war_policy === p ? 'selected' : '' %>><%= p %></option>
        <% }) %>
      </select>
    </div>
    <div class="form-group">
      <label>Domestic Policy</label>
      <select name="domestic_policy">
        <% DOMESTIC_POLICIES.forEach(p => { %>
          <option value="<%= p %>" <%= nation.domestic_policy === p ? 'selected' : '' %>><%= p %></option>
        <% }) %>
      </select>
    </div>
  </div>
  <div class="form-group">
    <label>Nation Color</label>
    <div class="color-picker">
      <% COLORS.forEach(c => { %>
        <label class="color-option">
          <input type="radio" name="color" value="<%= c %>" <%= nation.color === c ? 'checked' : '' %>>
          <span class="color-swatch" style="background-color: <%= c %>;" title="<%= c %>"></span>
        </label>
      <% }) %>
    </div>
  </div>
  <button type="submit" class="btn btn-primary">Save Changes</button>
  <a href="/nation/<%= nation.id %>" class="btn btn-secondary">Cancel</a>
</form>
<%- include('../partials/footer') %>
