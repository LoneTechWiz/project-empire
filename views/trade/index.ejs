<%- include('../partials/header', { title: 'Trade' }) %>

<div class="page-header">
  <h1>📈 Global Trade Market</h1>
  <% if (nation) { %><a href="/trade/create" class="btn btn-primary">Post Offer</a><% } %>
</div>

<% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
<% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

<!-- Filters -->
<form method="GET" action="/trade" class="filter-form">
  <select name="resource">
    <option value="all" <%= selectedResource === 'all' ? 'selected' : '' %>>All Resources</option>
    <% RESOURCES.forEach(r => { %>
      <option value="<%= r %>" <%= selectedResource === r ? 'selected' : '' %>><%= r %></option>
    <% }) %>
  </select>
  <select name="type">
    <option value="all" <%= selectedType === 'all' ? 'selected' : '' %>>Buy & Sell</option>
    <option value="buy" <%= selectedType === 'buy' ? 'selected' : '' %>>Buy Offers</option>
    <option value="sell" <%= selectedType === 'sell' ? 'selected' : '' %>>Sell Offers</option>
  </select>
  <button type="submit" class="btn btn-secondary">Filter</button>
</form>

<!-- Market Prices -->
<div class="panel">
  <h3>📊 Market Prices (7-day avg)</h3>
  <div class="market-prices">
    <% RESOURCES.forEach(r => { %>
      <div class="market-price-item">
        <span><%= resourceIcon(r) %> <%= r %></span>
        <span>$<%= formatNumber(marketPrices[r] || BASE_PRICES[r]) %></span>
      </div>
    <% }) %>
  </div>
</div>

<!-- Offers Table -->
<div class="panel">
  <h2>Active Offers (<%= offers.length %>)</h2>
  <% if (offers.length === 0) { %>
    <p class="text-muted">No offers matching your filter.</p>
  <% } else { %>
  <table class="data-table">
    <thead>
      <tr>
        <th>Type</th><th>Resource</th><th>Quantity</th><th>Price/Unit</th><th>Total</th><th>Nation</th><th>Posted</th><th>Action</th>
      </tr>
    </thead>
    <tbody>
      <% offers.forEach(o => { %>
      <tr class="offer-<%= o.offer_type %>">
        <td><span class="offer-badge offer-<%= o.offer_type %>"><%= o.offer_type.toUpperCase() %></span></td>
        <td><%= resourceIcon(o.resource) %> <%= o.resource %></td>
        <td><%= formatNumber(o.quantity) %></td>
        <td>$<%= formatNumber(o.price_per_unit) %></td>
        <td><%= formatMoney(o.quantity * o.price_per_unit) %></td>
        <td><a href="/nation/<%= o.nation_id %>"><%= o.nation_name %></a></td>
        <td><%= timeAgo(o.created_at) %></td>
        <td>
          <% if (nation && nation.id !== o.nation_id) { %>
            <form method="POST" action="/trade/accept/<%= o.id %>">
              <button class="btn btn-sm btn-primary">Accept</button>
            </form>
          <% } else if (nation && nation.id === o.nation_id) { %>
            <form method="POST" action="/trade/cancel/<%= o.id %>">
              <button class="btn btn-sm btn-danger">Cancel</button>
            </form>
          <% } %>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>

<!-- Recent Trades -->
<div class="panel">
  <h3>🕐 Recent Trades</h3>
  <% if (recentTrades.length === 0) { %>
    <p class="text-muted">No recent trades.</p>
  <% } else { %>
  <table class="data-table">
    <thead><tr><th>Resource</th><th>Qty</th><th>Price</th><th>Total</th><th>Buyer</th><th>Seller</th><th>Date</th></tr></thead>
    <tbody>
      <% recentTrades.forEach(t => { %>
      <tr>
        <td><%= resourceIcon(t.resource) %> <%= t.resource %></td>
        <td><%= formatNumber(t.quantity) %></td>
        <td>$<%= formatNumber(t.price_per_unit) %></td>
        <td><%= formatMoney(t.total) %></td>
        <td><a href="/nation/<%= t.buyer_id %>"><%= t.buyer_name %></a></td>
        <td><a href="/nation/<%= t.seller_id %>"><%= t.seller_name %></a></td>
        <td><%= timeAgo(t.date) %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>

<%- include('../partials/footer') %>
