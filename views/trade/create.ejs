<%- include('../partials/header', { title: 'Post Trade Offer' }) %>
<div class="page-header"><h1>📈 Post Trade Offer</h1></div>
<% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
<form method="POST" action="/trade/create" class="form-card">
  <div class="form-row">
    <div class="form-group">
      <label>Offer Type</label>
      <select name="offer_type">
        <option value="sell" <%= values.offer_type === 'sell' ? 'selected' : '' %>>Sell</option>
        <option value="buy" <%= values.offer_type === 'buy' ? 'selected' : '' %>>Buy</option>
      </select>
    </div>
    <div class="form-group">
      <label>Resource</label>
      <select name="resource">
        <% RESOURCES.forEach(r => { %>
          <option value="<%= r %>" <%= values.resource === r ? 'selected' : '' %>><%= resourceIcon(r) %> <%= r %> (stock: <%= formatNumber(nation[r]) %>)</option>
        <% }) %>
      </select>
    </div>
  </div>
  <div class="form-row">
    <div class="form-group">
      <label>Quantity</label>
      <input type="number" name="quantity" min="1" step="1" value="<%= values.quantity || 1000 %>" required>
    </div>
    <div class="form-group">
      <label>Price Per Unit ($)</label>
      <input type="number" name="price_per_unit" min="1" step="1" value="<%= values.price_per_unit || '' %>" required placeholder="Price per unit">
    </div>
  </div>
  <div class="panel" style="margin:16px 0; background: var(--bg-darker)">
    <h4>Base Market Prices (reference):</h4>
    <div class="market-prices compact">
      <% RESOURCES.forEach(r => { %>
        <span><%= resourceIcon(r) %> $<%= formatNumber(BASE_PRICES[r]) %></span>
      <% }) %>
    </div>
  </div>
  <button type="submit" class="btn btn-primary">Post Offer</button>
  <a href="/trade" class="btn btn-secondary">Cancel</a>
</form>
<%- include('../partials/footer') %>
