<%- include('../partials/header', { title: 'Messages' }) %>

<div class="page-header">
  <h1>✉️ Messages</h1>
  <a href="/messages/compose" class="btn btn-primary">New Message</a>
</div>

<div class="content-grid">
  <div class="content-main">
    <div class="panel">
      <h2>Inbox (<%= inbox.length %>)</h2>
      <% if (inbox.length === 0) { %><p class="text-muted">No messages.</p><% } %>
      <% inbox.forEach(m => { %>
        <div class="message-row <%= m.read ? '' : 'unread' %>">
          <img src="<%= m.sender_flag %>" style="width:25px;height:18px;object-fit:cover;" onerror="this.src='/img/default_flag.png'">
          <div class="message-info">
            <a href="/messages/<%= m.id %>"><strong><%= m.subject %></strong></a>
            <span class="message-from">From: <a href="/nation/<%= m.sender_id %>"><%= m.sender_name %></a></span>
          </div>
          <span class="message-time"><%= timeAgo(m.sent_at) %></span>
          <% if (!m.read) { %><span class="badge">New</span><% } %>
        </div>
      <% }) %>
    </div>

    <div class="panel">
      <h2>Sent</h2>
      <% if (sent.length === 0) { %><p class="text-muted">No sent messages.</p><% } %>
      <% sent.forEach(m => { %>
        <div class="message-row">
          <div class="message-info">
            <a href="/messages/<%= m.id %>"><strong><%= m.subject %></strong></a>
            <span class="message-from">To: <a href="/nation/<%= m.receiver_id %>"><%= m.receiver_name %></a></span>
          </div>
          <span class="message-time"><%= timeAgo(m.sent_at) %></span>
        </div>
      <% }) %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
