<%- include('../partials/header', { title: message.subject }) %>
<div class="page-header">
  <h1>✉️ <%= message.subject %></h1>
</div>
<div class="panel message-view">
  <div class="message-meta">
    <p>From: <a href="/nation/<%= message.sender_id %>"><strong><%= message.sender_name %></strong></a></p>
    <p>To: <a href="/nation/<%= message.receiver_id %>"><strong><%= message.receiver_name %></strong></a></p>
    <p>Sent: <%= new Date(message.sent_at).toLocaleString() %></p>
  </div>
  <div class="message-body">
    <% message.content.split('\n').forEach(line => { %>
      <p><%= line || '&nbsp;' %></p>
    <% }) %>
  </div>
  <div class="message-actions">
    <a href="/messages/compose?to=<%= message.sender_id %>" class="btn btn-primary">Reply</a>
    <a href="/messages" class="btn btn-secondary">Back to Inbox</a>
  </div>
</div>
<%- include('../partials/footer') %>
