<%- include('../partials/header', { title: 'Compose' }) %>
<div class="page-header"><h1>✉️ Compose Message</h1></div>
<% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
<form method="POST" action="/messages/compose" class="form-card">
  <div class="form-group">
    <label>To (Nation ID or search):</label>
    <input type="number" name="to_nation_id" value="<%= toNation ? toNation.id : '' %>" placeholder="Nation ID" required>
    <% if (toNation) { %><span class="text-muted">→ <%= toNation.name %></span><% } %>
  </div>
  <div class="form-group">
    <label>Subject</label>
    <input type="text" name="subject" placeholder="Subject" maxlength="100">
  </div>
  <div class="form-group">
    <label>Message</label>
    <textarea name="content" rows="8" required placeholder="Write your message..."></textarea>
  </div>
  <button type="submit" class="btn btn-primary">Send Message</button>
  <a href="/messages" class="btn btn-secondary">Cancel</a>
</form>
<%- include('../partials/footer') %>
