<%- include('partials/header', { title: 'Dashboard' }) %>

<div class="dashboard-header">
  <div class="dashboard-nation-info">
    <img src="<%= nation.flag_url %>" class="dash-flag" onerror="this.src='/img/default_flag.png'">
    <div>
      <h1><a href="/nation/<%= nation.id %>"><%= nation.name %></a></h1>
      <p>Led by <strong><%= nation.leader_name %></strong> &bull; <%= nation.government_type %> &bull; Rank #<%= rank %></p>
      <p>Score: <strong><%= formatDecimal(nation.score, 2) %></strong> &bull; Cities: <strong><%= cities.length %></strong></p>
      <% if (alliance) { %>
        <p><a href="/alliances/<%= alliance.id %>">[<%= alliance.acronym %>] <%= alliance.name %></a> &bull; <%= nation.alliance_position %></p>
      <% } %>
    </div>
  </div>
  <div class="dashboard-quick-actions">
    <a href="/cities" class="btn btn-secondary">🏙️ Cities</a>
    <a href="/military" class="btn btn-secondary">⚔️ Military</a>
    <a href="/trade" class="btn btn-secondary">📈 Trade</a>
    <a href="/wars" class="btn btn-secondary">💥 Wars</a>
  </div>
</div>

<!-- Alerts -->
<% if (activeWars.length > 0) { %>
<div class="alert alert-warning">
  ⚔️ You are in <strong><%= activeWars.length %></strong> active war(s).
  <a href="/wars">View Wars</a>
</div>
<% } %>

<div class="dashboard-grid">
  <!-- Resources Panel -->
  <div class="panel">
    <h2>💰 Resources</h2>
    <div class="resource-grid compact">
      <div class="resource-item"><span class="res-icon">💰</span><span class="res-label">Money</span><span class="res-value"><%= formatMoney(nation.money) %></span><span class="res-rate <%= (totalProduction.money||0) >= 0 ? 'pos' : 'neg' %>"><%= (totalProduction.money||0) >= 0 ? '+' : '' %><%= formatMoney(totalProduction.money||0) %>/turn</span></div>
      <div class="resource-item"><span class="res-icon">🌾</span><span class="res-label">Food</span><span class="res-value"><%= formatNumber(nation.food) %></span><span class="res-rate <%= (totalProduction.food||0) >= 0 ? 'pos' : 'neg' %>"><%= (totalProduction.food||0) >= 0 ? '+' : '' %><%= formatDecimal(totalProduction.food||0,1) %>/turn</span></div>
      <div class="resource-item"><span class="res-icon">⚫</span><span class="res-label">Coal</span><span class="res-value"><%= formatNumber(nation.coal) %></span><span class="res-rate pos">+<%= formatDecimal(totalProduction.coal||0,1) %>/turn</span></div>
      <div class="resource-item"><span class="res-icon">🛢️</span><span class="res-label">Oil</span><span class="res-value"><%= formatNumber(nation.oil) %></span><span class="res-rate pos">+<%= formatDecimal(totalProduction.oil||0,1) %>/turn</span></div>
      <div class="resource-item"><span class="res-icon">☢️</span><span class="res-label">Uranium</span><span class="res-value"><%= formatNumber(nation.uranium) %></span></div>
      <div class="resource-item"><span class="res-icon">🔩</span><span class="res-label">Iron</span><span class="res-value"><%= formatNumber(nation.iron) %></span></div>
      <div class="resource-item"><span class="res-icon">🪨</span><span class="res-label">Bauxite</span><span class="res-value"><%= formatNumber(nation.bauxite) %></span></div>
      <div class="resource-item"><span class="res-icon">🔘</span><span class="res-label">Lead</span><span class="res-value"><%= formatNumber(nation.lead) %></span></div>
      <div class="resource-item"><span class="res-icon">⛽</span><span class="res-label">Gas</span><span class="res-value"><%= formatNumber(nation.gasoline) %></span></div>
      <div class="resource-item"><span class="res-icon">💣</span><span class="res-label">Munitions</span><span class="res-value"><%= formatNumber(nation.munitions) %></span></div>
      <div class="resource-item"><span class="res-icon">🔧</span><span class="res-label">Steel</span><span class="res-value"><%= formatNumber(nation.steel) %></span></div>
      <div class="resource-item"><span class="res-icon">⬜</span><span class="res-label">Aluminum</span><span class="res-value"><%= formatNumber(nation.aluminum) %></span></div>
    </div>
  </div>

  <!-- Military Panel -->
  <div class="panel">
    <h2>⚔️ Military</h2>
    <div class="military-grid compact">
      <div class="mil-item"><span class="mil-icon">👥</span><span class="mil-label">Soldiers</span><span class="mil-value"><%= formatNumber(nation.soldiers) %></span></div>
      <div class="mil-item"><span class="mil-icon">🚗</span><span class="mil-label">Tanks</span><span class="mil-value"><%= formatNumber(nation.tanks) %></span></div>
      <div class="mil-item"><span class="mil-icon">✈️</span><span class="mil-label">Aircraft</span><span class="mil-value"><%= formatNumber(nation.aircraft) %></span></div>
      <div class="mil-item"><span class="mil-icon">🚢</span><span class="mil-label">Ships</span><span class="mil-value"><%= formatNumber(nation.ships) %></span></div>
      <div class="mil-item"><span class="mil-icon">🕵️</span><span class="mil-label">Spies</span><span class="mil-value"><%= formatNumber(nation.spies) %></span></div>
      <div class="mil-item"><span class="mil-icon">🚀</span><span class="mil-label">Missiles</span><span class="mil-value"><%= formatNumber(nation.missiles) %></span></div>
      <div class="mil-item"><span class="mil-icon">☢️</span><span class="mil-label">Nukes</span><span class="mil-value"><%= formatNumber(nation.nukes) %></span></div>
    </div>
    <a href="/military" class="btn btn-secondary btn-sm">Manage Military</a>
  </div>

  <!-- Active Wars -->
  <div class="panel">
    <h2>⚔️ Active Wars</h2>
    <% if (activeWars.length === 0) { %>
      <p class="text-muted">No active wars.</p>
    <% } else { %>
      <% activeWars.forEach(w => { %>
        <div class="war-item">
          <a href="/wars/<%= w.id %>">
            <strong><%= w.attacker_name %></strong> vs <strong><%= w.defender_name %></strong>
          </a>
          <span class="war-resistance">
            ATK: <%= w.attacker_resistance %> | DEF: <%= w.defender_resistance %>
          </span>
        </div>
      <% }) %>
    <% } %>
    <a href="/wars" class="btn btn-secondary btn-sm">War Room</a>
  </div>

  <!-- Recent Activity -->
  <div class="panel">
    <h2>📜 Activity</h2>
    <% if (recentActivity.length === 0) { %>
      <p class="text-muted">No recent activity.</p>
    <% } else { %>
      <% recentActivity.forEach(a => { %>
        <div class="activity-item">
          <span class="activity-msg"><%= a.message %></span>
          <span class="activity-time"><%= timeAgo(a.created_at) %></span>
        </div>
      <% }) %>
    <% } %>
  </div>

  <!-- World News -->
  <div class="panel panel-wide">
    <h2>🌍 World News</h2>
    <% if (worldNews.length === 0) { %>
      <p class="text-muted">Nothing happening yet.</p>
    <% } else { %>
      <div class="news-feed">
        <% worldNews.forEach(n => { %>
          <div class="news-item">
            <span class="news-nation"><a href="/nation/<%= n.nation_id %>"><%= n.nation_name %></a></span>
            <span class="news-msg"><%= n.message %></span>
            <span class="news-time"><%= timeAgo(n.created_at) %></span>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
