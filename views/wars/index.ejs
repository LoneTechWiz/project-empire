<%- include('../partials/header', { title: 'Wars' }) %>

<div class="page-header">
  <h1>💥 War Room</h1>
</div>

<% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
<% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

<div class="content-grid">
  <div class="content-main">
    <!-- Offensive Wars -->
    <div class="panel">
      <h2>⚔️ Offensive Wars (<%= offensiveWars.length %>/5)</h2>
      <% if (offensiveWars.length === 0) { %>
        <p class="text-muted">No offensive wars.</p>
      <% } %>
      <% offensiveWars.forEach(w => { %>
        <div class="war-row">
          <div class="war-row-info">
            <img src="<%= w.enemy_flag %>" class="war-flag" onerror="this.src='/img/default_flag.png'">
            <div>
              <a href="/wars/<%= w.id %>"><strong>vs. <%= w.enemy_name %></strong></a>
              <span class="war-date">Started <%= timeAgo(w.start_date) %></span>
            </div>
          </div>
          <div class="war-resistance-display">
            <div class="resist-bar-wrap">
              <div class="resist-label">You: <%= w.attacker_resistance %>%</div>
              <div class="resist-bar atk" style="width:<%= w.attacker_resistance %>%"></div>
            </div>
            <div class="resist-bar-wrap">
              <div class="resist-label">Enemy: <%= w.defender_resistance %>%</div>
              <div class="resist-bar def" style="width:<%= w.defender_resistance %>%"></div>
            </div>
          </div>
          <div class="war-row-actions">
            <a href="/wars/<%= w.id %>" class="btn btn-primary btn-sm">Attack</a>
            <form method="POST" action="/wars/<%= w.id %>/peace" style="display:inline">
              <button class="btn btn-secondary btn-sm">Peace</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>

    <!-- Defensive Wars -->
    <div class="panel">
      <h2>🛡️ Defensive Wars (<%= defensiveWars.length %>/3)</h2>
      <% if (defensiveWars.length === 0) { %>
        <p class="text-muted">No defensive wars.</p>
      <% } %>
      <% defensiveWars.forEach(w => { %>
        <div class="war-row">
          <div class="war-row-info">
            <img src="<%= w.enemy_flag %>" class="war-flag" onerror="this.src='/img/default_flag.png'">
            <div>
              <a href="/wars/<%= w.id %>"><strong>vs. <%= w.enemy_name %></strong></a>
              <span class="war-date">Started <%= timeAgo(w.start_date) %></span>
            </div>
          </div>
          <div class="war-resistance-display">
            <div class="resist-bar-wrap">
              <div class="resist-label">You: <%= w.defender_resistance %>%</div>
              <div class="resist-bar def" style="width:<%= w.defender_resistance %>%"></div>
            </div>
            <div class="resist-bar-wrap">
              <div class="resist-label">Attacker: <%= w.attacker_resistance %>%</div>
              <div class="resist-bar atk" style="width:<%= w.attacker_resistance %>%"></div>
            </div>
          </div>
          <div class="war-row-actions">
            <a href="/wars/<%= w.id %>" class="btn btn-primary btn-sm">Defend</a>
            <form method="POST" action="/wars/<%= w.id %>/peace" style="display:inline">
              <button class="btn btn-secondary btn-sm">Peace</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>

    <!-- Past Wars -->
    <div class="panel">
      <h2>📜 War History</h2>
      <% if (recentWars.length === 0) { %><p class="text-muted">No past wars.</p><% } %>
      <% recentWars.forEach(w => { %>
        <div class="war-row past">
          <span class="war-status <%= w.status %>"><%= w.status %></span>
          <a href="/wars/<%= w.id %>"><%= w.attacker_name %> vs <%= w.defender_name %></a>
          <span class="war-date"><%= timeAgo(w.end_date) %></span>
        </div>
      <% }) %>
    </div>
  </div>

  <div class="content-sidebar">
    <div class="panel">
      <h3>⚔️ Declare War</h3>
      <p>Search for a nation to attack:</p>
      <form method="GET" action="/search">
        <input type="text" name="q" placeholder="Nation name...">
        <button type="submit" class="btn btn-danger btn-sm">Search</button>
      </form>
    </div>
    <div class="panel">
      <h3>📊 War Stats</h3>
      <div>Offensive Wins: <strong><%= nation.offensive_wars_won %></strong></div>
      <div>Offensive Losses: <strong><%= nation.offensive_wars_lost %></strong></div>
      <div>Defensive Wins: <strong><%= nation.defensive_wars_won %></strong></div>
      <div>Defensive Losses: <strong><%= nation.defensive_wars_lost %></strong></div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
