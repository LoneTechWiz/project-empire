<%- include('../partials/header', { title: 'Declare War' }) %>

<div class="page-header">
  <h1>⚔️ Declare War</h1>
</div>

<% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

<div class="panel declare-war-panel">
  <div class="war-target-info">
    <img src="<%= target.flag_url %>" class="war-target-flag" onerror="this.src='/img/default_flag.png'">
    <div>
      <h2><a href="/nation/<%= target.id %>"><%= target.name %></a></h2>
      <p>Leader: <strong><%= target.leader_name %></strong> &bull; <%= target.government_type %></p>
      <p>Score: <strong><%= formatDecimal(target.score, 2) %></strong></p>
      <p>Military: 👥<%= formatNumber(target.soldiers) %> | 🚗<%= formatNumber(target.tanks) %> | ✈️<%= formatNumber(target.aircraft) %> | 🚢<%= formatNumber(target.ships) %></p>
      <% if (target.beige_turns > 0) { %>
        <div class="alert alert-warning">⚠️ This nation is on Beige protection (<%= target.beige_turns %> turns remaining)</div>
      <% } %>
    </div>
  </div>

  <form method="POST" action="/wars/declare/<%= target.id %>">
    <div class="form-group">
      <label>War Reason (optional)</label>
      <input type="text" name="reason" placeholder="State your reason for war..." maxlength="200">
    </div>
    <div class="war-confirm">
      <p class="warning-text">⚠️ Declaring war is a serious action. This cannot be easily undone.</p>
      <button type="submit" class="btn btn-danger btn-large">⚔️ Declare War on <%= target.name %></button>
      <a href="/wars" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
