<%- include('partials/header', { title: 'Search' }) %>

<div class="page-header">
  <h1>🔍 Search</h1>
</div>

<form method="GET" action="/search" class="search-form">
  <input type="text" name="q" value="<%= q %>" placeholder="Search nations, alliances..." autofocus>
  <button type="submit" class="btn btn-primary">Search</button>
</form>

<% if (q) { %>
  <!-- Nations -->
  <div class="panel">
    <h2>Nations (<%= nations.length %>)</h2>
    <% if (nations.length === 0) { %><p class="text-muted">No nations found.</p><% } %>
    <% nations.forEach(n => { %>
      <div class="search-result">
        <img src="<%= n.flag_url %>" style="width:30px;height:21px;object-fit:cover;" onerror="this.src='/img/default_flag.png'">
        <div>
          <a href="/nation/<%= n.id %>"><strong><%= n.name %></strong></a>
          <span class="text-muted">Led by <%= n.leader_name %> &bull; <%= n.continent %></span>
          <span>Score: <%= formatDecimal(n.score, 2) %></span>
        </div>
        <% if (nation && nation.id !== n.id) { %>
          <div>
            <a href="/wars/declare/<%= n.id %>" class="btn btn-sm btn-danger">⚔️ Attack</a>
            <a href="/messages/compose?to=<%= n.id %>" class="btn btn-sm btn-secondary">✉️ Message</a>
          </div>
        <% } %>
      </div>
    <% }) %>
  </div>

  <!-- Alliances -->
  <div class="panel">
    <h2>Alliances (<%= alliances.length %>)</h2>
    <% if (alliances.length === 0) { %><p class="text-muted">No alliances found.</p><% } %>
    <% alliances.forEach(a => { %>
      <div class="search-result">
        <a href="/alliances/<%= a.id %>"><strong>[<%= a.acronym %>] <%= a.name %></strong></a>
      </div>
    <% }) %>
  </div>
<% } %>

<%- include('partials/footer') %>
