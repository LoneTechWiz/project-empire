<%- include('../partials/header', { title: city.name }) %>

<div class="page-header">
  <h1>🏙️ <%= city.name %></h1>
  <p>Money: <strong><%= formatMoney(nation.money) %></strong> &bull;
    Power: <strong class="<%= power.powered ? 'text-green' : 'text-red' %>">
      <%= power.available.toFixed(0) %>/<%= power.needed.toFixed(0) %> MW
    </strong> &bull;
    Commerce: <strong><%= commerce %>%</strong>
  </p>
</div>

<% if (error) { %><div class="alert alert-error"><%= decodeURIComponent(error) %></div><% } %>

<!-- Infrastructure & Land -->
<div class="panel">
  <h2>Infrastructure & Land</h2>
  <div class="infra-stats">
    <div>Current Infrastructure: <strong><%= formatDecimal(city.infrastructure, 2) %></strong></div>
    <div>Land: <strong><%= formatDecimal(city.land, 0) %> mi²</strong></div>
  </div>
  <div class="form-row">
    <form method="POST" action="/cities/<%= city.id %>/infra" class="inline-form">
      <label>Upgrade Infrastructure to:</label>
      <input type="number" name="target" min="<%= Math.ceil(city.infrastructure)+1 %>" max="5000" step="1" value="<%= Math.ceil(city.infrastructure)+100 %>">
      <button type="submit" class="btn btn-primary">Upgrade</button>
    </form>
    <form method="POST" action="/cities/<%= city.id %>/land" class="inline-form">
      <label>Buy Land (mi² @ $400/mi²):</label>
      <input type="number" name="amount" min="1" max="5000" step="1" value="100">
      <button type="submit" class="btn btn-primary">Buy Land</button>
    </form>
  </div>
</div>

<!-- Improvements -->
<div class="improvements-grid">

  <!-- Power Plants -->
  <div class="imp-section">
    <h3>⚡ Power Plants</h3>
    <% const powerImps = ['imp_coalpower','imp_oilpower','imp_nuclearpower','imp_windpower']; %>
    <% powerImps.forEach(imp => { %>
      <div class="imp-item">
        <div class="imp-info">
          <span class="imp-name"><%= IMP_NAMES[imp] %></span>
          <span class="imp-count"><%= city[imp] %> / <%= MAX_PER_IMP[imp] %></span>
          <span class="imp-cost"><%= formatMoney(IMP_COSTS[imp]) %></span>
        </div>
        <div class="imp-actions">
          <form method="POST" action="/cities/<%= city.id %>/build" style="display:inline">
            <input type="hidden" name="improvement" value="<%= imp %>">
            <button class="btn btn-sm btn-primary" <%= (city[imp] >= MAX_PER_IMP[imp] || nation.money < IMP_COSTS[imp]) ? 'disabled' : '' %>>+</button>
          </form>
          <form method="POST" action="/cities/<%= city.id %>/demolish" style="display:inline">
            <input type="hidden" name="improvement" value="<%= imp %>">
            <button class="btn btn-sm btn-danger" <%= city[imp] <= 0 ? 'disabled' : '' %>>-</button>
          </form>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Raw Resources -->
  <div class="imp-section">
    <h3>⛏️ Resource Extraction</h3>
    <% const mineImps = ['imp_coalmine','imp_oilwell','imp_ironmine','imp_bauxitemine','imp_leadmine','imp_uraniummine','imp_farm']; %>
    <% mineImps.forEach(imp => { %>
      <div class="imp-item">
        <div class="imp-info">
          <span class="imp-name"><%= IMP_NAMES[imp] %></span>
          <span class="imp-count"><%= city[imp] %> / <%= MAX_PER_IMP[imp] %></span>
          <span class="imp-cost"><%= formatMoney(IMP_COSTS[imp]) %></span>
        </div>
        <div class="imp-actions">
          <form method="POST" action="/cities/<%= city.id %>/build" style="display:inline">
            <input type="hidden" name="improvement" value="<%= imp %>">
            <button class="btn btn-sm btn-primary" <%= (city[imp] >= MAX_PER_IMP[imp] || nation.money < IMP_COSTS[imp]) ? 'disabled' : '' %>>+</button>
          </form>
          <form method="POST" action="/cities/<%= city.id %>/demolish" style="display:inline">
            <input type="hidden" name="improvement" value="<%= imp %>">
            <button class="btn btn-sm btn-danger" <%= city[imp] <= 0 ? 'disabled' : '' %>>-</button>
          </form>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Industry -->
  <div class="imp-section">
    <h3>🏭 Industry</h3>
    <% const industryImps = ['imp_oilrefinery','imp_steelmill','imp_aluminumrefinery','imp_munitionsfactory']; %>
    <% industryImps.forEach(imp => { %>
      <div class="imp-item">
        <div class="imp-info">
          <span class="imp-name"><%= IMP_NAMES[imp] %></span>
          <span class="imp-count"><%= city[imp] %> / <%= MAX_PER_IMP[imp] %></span>
          <span class="imp-cost"><%= formatMoney(IMP_COSTS[imp]) %></span>
        </div>
        <div class="imp-actions">
          <form method="POST" action="/cities/<%= city.id %>/build" style="display:inline">
            <input type="hidden" name="improvement" value="<%= imp %>">
            <button class="btn btn-sm btn-primary" <%= (city[imp] >= MAX_PER_IMP[imp] || nation.money < IMP_COSTS[imp]) ? 'disabled' : '' %>>+</button>
          </form>
          <form method="POST" action="/cities/<%= city.id %>/demolish" style="display:inline">
            <input type="hidden" name="improvement" value="<%= imp %>">
            <button class="btn btn-sm btn-danger" <%= city[imp] <= 0 ? 'disabled' : '' %>>-</button>
          </form>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Commerce -->
  <div class="imp-section">
    <h3>🏪 Commerce</h3>
    <% const commerceImps = ['imp_policestation','imp_hospital','imp_recyclingcenter','imp_subway','imp_supermarket','imp_bank','imp_mall','imp_stadium']; %>
    <% commerceImps.forEach(imp => { %>
      <div class="imp-item">
        <div class="imp-info">
          <span class="imp-name"><%= IMP_NAMES[imp] %></span>
          <span class="imp-count"><%= city[imp] %> / <%= MAX_PER_IMP[imp] %></span>
          <span class="imp-cost"><%= formatMoney(IMP_COSTS[imp]) %></span>
        </div>
        <div class="imp-actions">
          <form method="POST" action="/cities/<%= city.id %>/build" style="display:inline">
            <input type="hidden" name="improvement" value="<%= imp %>">
            <button class="btn btn-sm btn-primary" <%= (city[imp] >= MAX_PER_IMP[imp] || nation.money < IMP_COSTS[imp]) ? 'disabled' : '' %>>+</button>
          </form>
          <form method="POST" action="/cities/<%= city.id %>/demolish" style="display:inline">
            <input type="hidden" name="improvement" value="<%= imp %>">
            <button class="btn btn-sm btn-danger" <%= city[imp] <= 0 ? 'disabled' : '' %>>-</button>
          </form>
        </div>
      </div>
    <% }) %>
  </div>
</div>

<!-- Production Summary -->
<div class="panel">
  <h2>📊 Production This Turn</h2>
  <div class="resource-grid">
    <% for (const [r, v] of Object.entries(production)) { %>
      <% if (v !== 0) { %>
      <div class="resource-item">
        <span class="res-icon"><%= resourceIcon(r) %></span>
        <span class="res-label"><%= r %></span>
        <span class="res-value <%= v > 0 ? 'text-green' : 'text-red' %>">
          <%= v > 0 ? '+' : '' %><%= formatDecimal(v, 2) %>
        </span>
      </div>
      <% } %>
    <% } %>
  </div>
</div>

<a href="/cities" class="btn btn-secondary">← Back to Cities</a>

<%- include('../partials/footer') %>
